// Prisma schema for PROJETO CROCHÊ
// Multi-tenant SaaS for crochet artisans

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// AUTH — email + password (custom sessions)
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String
  image        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions         Session[]
  workspaceMembers WorkspaceMember[]
  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// WORKSPACE (ATELIER) — MULTI-TENANT
// ─────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members WorkspaceMember[]

  subscription      Subscription?
  usageCounters     UsageCounter[]
  yarns             Yarn[]
  stockItems        StockItem[]
  materials         Material[]
  priceCalculations PriceCalculation[]
  products          Product[]
  transactions      Transaction[]
  monthlyGoals      MonthlyGoal[]
  orders            Order[]
  customers         Customer[]
  timeEntries       TimeEntry[]
  overheadCosts     OverheadCost[]
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(OWNER)
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

// ─────────────────────────────────────────
// SUBSCRIPTION & BILLING
// ─────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  workspaceId          String             @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  accessStatus         AccessStatus       @default(TRIAL)
  trialStartAt         DateTime?
  trialEndAt           DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  asaasCustomerId      String?
  asaasSubscriptionId  String?
  lastPaymentAt        DateTime?
  lastAsaasPaymentId   String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum AccessStatus {
  TRIAL
  ACTIVE
  BLOCKED
}

enum Plan {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

model UsageCounter {
  id                       String   @id @default(cuid())
  workspaceId              String
  monthYYYYMM              String
  pricingCalculationsCount Int      @default(0)
  transactionsCount        Int      @default(0)
  productsCount            Int      @default(0)
  updatedAt                DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, monthYYYYMM])
}

// ─────────────────────────────────────────
// INVENTORY — FINISHED PRODUCTS STOCK
// ─────────────────────────────────────────

model Yarn {
  id                String   @id @default(cuid())
  workspaceId       String
  brand             String
  line              String?
  color             String
  gramsAvailable    Float    @default(0)
  costTotal         Float    @default(0)
  lowStockThreshold Float    @default(50)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model StockItem {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String?
  size        String?
  quantity    Int      @default(0)
  price       Float?
  cost        Float?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─────────────────────────────────────────
// PRICING CALCULATOR
// ─────────────────────────────────────────

model PriceCalculation {
  id          String   @id @default(cuid())
  workspaceId String
  name        String?
  inputsJson  Json
  totalsJson  Json
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id])
  productId String?
}

// ─────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────

model Product {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String?
  status      ProductStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  variants          ProductVariant[]
  priceCalculations PriceCalculation[]
  timeEntries       TimeEntry[]
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  color     String?
  size      String?
  sku       String?
  price     Float?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

// ─────────────────────────────────────────
// FINANCE
// ─────────────────────────────────────────

model Transaction {
  id          String          @id @default(cuid())
  workspaceId String
  type        TransactionType
  category    String
  amount      Float
  date        DateTime
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

enum TransactionType {
  IN
  OUT
}

// ─────────────────────────────────────────
// CUSTOMERS (CLIENTES)
// ─────────────────────────────────────────

model Customer {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  instagram   String?
  whatsapp    String?
  city        String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([workspaceId, name])
}

// ─────────────────────────────────────────
// ORDERS (ENCOMENDAS)
// ─────────────────────────────────────────

enum PaymentStatus {
  UNPAID
  HALF_PAID
  PAID
}

enum ProductionStatus {
  TODO
  IN_PROGRESS
  FINISHING
  READY
  DELIVERED
}

model Order {
  id               String           @id @default(cuid())
  workspaceId      String
  orderDate        DateTime         @default(now())
  dueDate          DateTime
  customerId       String?
  customerName     String
  itemDescription  String
  amount           Float
  paymentStatus    PaymentStatus    @default(UNPAID)
  productionStatus ProductionStatus @default(TODO)
  checklistJson    Json?
  notes            String?
  channel          String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customer    Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]

  @@index([workspaceId, dueDate])
  @@index([workspaceId, paymentStatus])
  @@index([workspaceId, productionStatus])
}

// ─────────────────────────────────────────
// TIME TRACKING
// ─────────────────────────────────────────

model TimeEntry {
  id          String   @id @default(cuid())
  workspaceId String
  orderId     String?
  productId   String?
  stage       String
  minutes     Int
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  order     Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
}

// ─────────────────────────────────────────
// MONTHLY GOALS
// ─────────────────────────────────────────

model MonthlyGoal {
  id          String   @id @default(cuid())
  workspaceId String
  monthYYYYMM String
  revenueGoal Float    @default(0)
  profitGoal  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, monthYYYYMM])
}

// ─────────────────────────────────────────
// MATERIALS CATALOG (Catálogo de Insumos)
// ─────────────────────────────────────────

enum MaterialUnit {
  GRAMS
  METERS
  UNITS
  PACKS
}

enum MaterialCategory {
  YARN
  FILLING
  EYES
  LABEL
  BUTTON
  ZIPPER
  RING
  PACKAGING
  TAG
  GIFT
  OTHER
}

model Material {
  id             String           @id @default(cuid())
  workspaceId    String
  name           String
  category       MaterialCategory @default(OTHER)
  brand          String?
  color          String?
  unit           MaterialUnit     @default(UNITS)
  costPerUnit    Float
  stock          Float            @default(0)
  lowStockMin    Float            @default(0)
  supplier       String?
  notes          String?
  // Campos específicos para fio/lã (YARN)
  weightPerRoll  Float?           // peso por rolo em gramas
  pricePerRoll   Float?           // preço pago por rolo (R$)
  rolls          Int?             // quantidade de rolos em estoque
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, category])
}

// ─────────────────────────────────────────
// OVERHEAD COSTS (Custos Fixos do Ateliê)
// ─────────────────────────────────────────

model OverheadCost {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  amount      Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ─────────────────────────────────────────
// PAYMENT CONFIG (Configurações de Pagamento)
// ─────────────────────────────────────────

enum PaymentEnv {
  SANDBOX
  PRODUCTION
}

model PaymentConfig {
  id           String     @id @default(cuid())
  provider     String     @default("ASAAS")
  apiKeyEnc    String
  environment  PaymentEnv @default(SANDBOX)
  isActive     Boolean    @default(true)
  lastTestedAt DateTime?
  lastTestOk   Boolean?
  lastTestMsg  String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
